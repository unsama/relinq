---
const currentYear = new Date().getFullYear();
const links = {
  company: [
    { label: 'Home', href: '/' },
    { label: 'About Us', href: '/about' },
    { label: 'R2 Certification', href: '/#trust' },
    { label: 'Contact Us', href: '/contact' },
  ],
  categories: [
    { label: 'Refurbished Laptops', href: '/products?category=laptops' },
    { label: 'Desktops & Towers', href: '/products?category=desktops' },
    { label: 'LCD Displays', href: '/products?category=lcds' },
    { label: 'RAM & SSDs', href: '/products?category=components' },
  ],
};
---

<footer class="bg-slate-900 border-t border-slate-800 text-slate-300">
  <div class="max-w-7xl mx-auto px-4 md:px-6 pt-16 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-12">
      <!-- Brand & Info -->
      <div class="md:col-span-2">
        <a href="/" class="flex flex-col mb-4">
          <span class="text-2xl font-black text-white tracking-tight leading-none text-[#1E3A8A]">Relinq</span>
          <span class="text-sm uppercase tracking-widest text-white/70 font-bold mt-0.5">Solutions</span>
        </a>
        <p class="text-sm leading-relaxed max-w-md text-slate-400 mb-6">
          Empowering Pakistan's businesses with premium imported and R2 refurbished IT hardware. 
          Quality, reliability, and scale tailored for B2B needs.
        </p>
        
        <div class="flex items-center gap-2 text-sm text-slate-400 mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-500"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          Office 1307, 13th Floor United Center, Saddar Karachi
        </div>

        <div class="mt-6">
          <a href="https://chat.whatsapp.com/invite-link" class="inline-flex items-center gap-2 px-4 py-2 bg-[#22C55E]/10 text-[#22C55E] border border-[#22C55E]/20 rounded font-semibold text-sm hover:bg-[#22C55E]/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 21 1.65-3.8a9 9 0 1 1 3.4 2.9L3 21"/><path d="M9 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1a5 5 0 0 0 5 5h1a.5.5 0 0 0 0-1h-1a.5.5 0 0 0 0 1"/></svg>
            Join our WhatsApp Wholesale Group
          </a>
        </div>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-sm font-bold text-white mb-4 uppercase tracking-widest">Shop Categories</h4>
        <ul class="space-y-3">
          {links.categories.map(l => (
            <li><a href={l.href} class="text-sm hover:text-white transition-colors duration-200 flex items-center gap-2"><span class="w-1 h-1 rounded bg-[#1E3A8A]"></span>{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-sm font-bold text-white mb-4 uppercase tracking-widest">Company</h4>
        <ul class="space-y-3">
          {links.company.map(l => (
            <li><a href={l.href} class="text-sm hover:text-white transition-colors duration-200">{l.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-slate-800 pt-6 flex flex-col md:flex-row justify-between items-center gap-4 text-xs">
      <p class="text-slate-500">
        &copy; {currentYear} Relinq Solutions Pvt. Ltd. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        <span class="px-2 py-1 bg-slate-800 rounded text-slate-400">R2 Certified Partner</span>
        <span class="px-2 py-1 bg-slate-800 rounded text-slate-400">3-Day Refund Policy</span>
      </div>
    </div>
  </div>
</footer>
