---
const currentYear = new Date().getFullYear();
const links = {
  company: [
    { label: 'Home', href: '/' },
    { label: 'About Us', href: '/about' },
    { label: 'Services', href: '/#services' },
    { label: 'Our Journey', href: '/about#journey' },
  ],
  services: [
    { label: 'Wholesale IT Hardware', href: '/#services' },
    { label: 'Corporate AMC', href: '/#services' },
    { label: 'R2 Refurbishing', href: '/#services' },
    { label: 'Remote IT Support', href: '/#services' },
  ],
};
---

<footer class="bg-gray-950 text-gray-400">
  <div class="max-w-7xl mx-auto px-6 pt-16 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-12">
      <!-- Brand -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-blue-600 to-indigo-700 flex items-center justify-center text-white font-black text-lg">
            R
          </div>
          <span class="text-xl font-black text-white tracking-tight">Relinq<span class="text-blue-500">.</span></span>
        </div>
        <p class="text-sm leading-relaxed max-w-sm text-gray-400">
          22 years of trusted IT solutions. R2-certified. Dell, HP & Apple authorized. Backed by a 3-day refund policy.
        </p>
        <div class="flex items-center gap-3 mt-6">
          <span class="text-xs px-3 py-1 bg-blue-900/40 text-blue-400 rounded-full font-semibold border border-blue-800/50">R2 Certified</span>
          <span class="text-xs px-3 py-1 bg-green-900/40 text-green-400 rounded-full font-semibold border border-green-800/50">Est. 2004</span>
        </div>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-sm font-bold text-white mb-4 uppercase tracking-widest">Company</h4>
        <ul class="space-y-2">
          {links.company.map(l => (
            <li><a href={l.href} class="text-sm hover:text-blue-400 transition-colors duration-200">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-sm font-bold text-white mb-4 uppercase tracking-widest">Services</h4>
        <ul class="space-y-2">
          {links.services.map(l => (
            <li><a href={l.href} class="text-sm hover:text-blue-400 transition-colors duration-200">{l.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-gray-800 pt-6 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-gray-600">
        &copy; {currentYear} Relinq. All rights reserved. R2 Certified Importer.
      </p>
      <p class="text-xs text-gray-600">
        Authorized reseller: Dell · HP · Apple
      </p>
    </div>
  </div>
</footer>
