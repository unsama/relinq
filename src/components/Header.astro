---
const categories = [
  { label: 'Laptops', href: '/products?category=laptops' },
  { label: 'Desktops', href: '/products?category=desktops' },
  { label: 'LCDs', href: '/products?category=lcds' },
  { label: 'Components', href: '/products?category=components' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[#1E3A8A] text-white shadow-md">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <div class="flex items-center justify-between py-4">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group mr-4 md:mr-8">
        <div class="w-10 h-10 rounded bg-white flex items-center justify-center text-[#1E3A8A] font-black text-xl shadow-sm">
          R
        </div>
        <div class="flex flex-col">
          <span class="text-xl md:text-2xl font-black tracking-tight leading-none">Relinq</span>
          <span class="text-[10px] uppercase tracking-widest text-[#64748B] font-bold mt-0.5">Solutions</span>
        </div>
      </a>

      <!-- Search Bar -->
      <div class="hidden md:flex flex-1 max-w-xl mx-8">
        <div class="relative w-full">
          <input 
            type="text" 
            placeholder="Search our wholesale inventory..." 
            class="w-full bg-white/10 border border-white/20 rounded-md py-2.5 px-4 text-white placeholder-white/70 focus:outline-none focus:ring-2 focus:ring-[#22C55E] focus:bg-white/20 transition-all font-medium"
          />
          <button class="absolute right-3 top-1/2 -translate-y-1/2 text-white/70 hover:text-white">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </button>
        </div>
      </div>

      <!-- CTA -->
      <div class="flex items-center gap-4">
        <a
          href="https://wa.me/923000000000?text=I'd%20like%20a%20wholesale%20quote"
          class="hidden md:flex text-sm font-bold px-6 py-2.5 rounded-md bg-[#22C55E] hover:bg-[#16A34A] text-white shadow-lg transition-transform hover:-translate-y-0.5 whitespace-nowrap"
        >
          Request a Wholesale Quote
        </a>
      </div>
    </div>

    <!-- Category Nav -->
    <div class="hidden md:flex items-center border-t border-white/10 py-3 gap-8">
      <div class="relative group">
        <button class="flex items-center gap-2 font-semibold text-sm hover:text-blue-200 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
          Shop Categories
        </button>
        <!-- Dropdown (CSS only for demo) -->
        <div class="absolute left-0 top-full pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
          <div class="bg-white rounded-md shadow-xl overflow-hidden border border-gray-100 min-w-48 text-[#0F172A]">
            {categories.map(cat => (
              <a href={cat.href} class="block px-4 py-3 text-sm font-medium hover:bg-gray-50 border-b border-gray-50 last:border-0 hover:text-[#1E3A8A]">
                {cat.label}
              </a>
            ))}
          </div>
        </div>
      </div>
      
      <a href="/about" class="text-sm font-medium text-white/90 hover:text-white transition-colors">About Us</a>
      <a href="/#trust" class="text-sm font-medium text-white/90 hover:text-white transition-colors">R2 Certification</a>
      <a href="/#brands" class="text-sm font-medium text-white/90 hover:text-white transition-colors">Brands</a>
    </div>
  </div>
</header>
