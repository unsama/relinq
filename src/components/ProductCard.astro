---
interface Props {
  title: string;
  brand: string;
  specs: string[];
  imageUrl: string;
  stockStatus: string;
}

const { title, brand, specs, imageUrl, stockStatus } = Astro.props;
---

<div class="bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-xl transition-shadow duration-300 overflow-hidden group flex flex-col h-full">
  <div class="relative bg-gray-50 aspect-square p-6 flex items-center justify-center">
    <div class="absolute top-3 right-3 bg-[#1E3A8A]/10 text-[#1E3A8A] text-xs font-bold px-2 py-1 rounded">
      {brand}
    </div>
    <img src={imageUrl} alt={title} class="max-h-full max-w-full object-contain group-hover:scale-105 transition-transform duration-500 Mix-blend-multiply" />
  </div>
  
  <div class="p-5 flex flex-col flex-1">
    <div class="mb-1 text-xs font-semibold text-[#22C55E] tracking-wider uppercase">
      {stockStatus}
    </div>
    <h3 class="font-bold text-gray-900 leading-tight mb-3 text-lg line-clamp-2">
      {title}
    </h3>
    
    <ul class="space-y-1 mb-6 flex-1">
      {specs.map(spec => (
        <li class="text-xs text-gray-600 flex items-start gap-2">
          <svg class="text-[#64748B] w-3 h-3 mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          <span class="line-clamp-1">{spec}</span>
        </li>
      ))}
    </ul>
    
    <div class="flex flex-col gap-2 mt-auto">
      <a href={`https://wa.me/923000000000?text=I'd%20like%20a%20wholesale%20price%20for:%20${encodeURIComponent(title)}`} class="w-full text-center text-sm font-bold bg-[#1E3A8A] text-white py-2.5 rounded-lg hover:bg-[#1E3A8A]/90 transition-colors">
        Request Wholesale Price
      </a>
      <button class="w-full text-center text-sm font-semibold text-[#1E3A8A] bg-[#1E3A8A]/5 py-2 rounded-lg hover:bg-[#1E3A8A]/10 transition-colors border border-[#1E3A8A]/10">
        View Details
      </button>
    </div>
  </div>
</div>
