---
interface Props {
  icon: string;
  title: string;
  description: string;
  badge?: string;
  highlight?: boolean;
}

const { icon, title, description, badge, highlight = false } = Astro.props;
---

<div class={`group relative rounded-2xl p-8 border transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl cursor-default ${highlight ? 'bg-gradient-to-br from-blue-600 to-indigo-700 border-blue-500 text-white' : 'bg-white border-gray-100 hover:border-blue-200'}`}>
  {badge && (
    <span class={`absolute top-4 right-4 text-xs font-bold px-3 py-1 rounded-full ${highlight ? 'bg-white/20 text-white' : 'bg-blue-50 text-blue-600'}`}>
      {badge}
    </span>
  )}
  <div class={`text-4xl mb-5 transition-transform duration-300 group-hover:scale-110 inline-block`}>
    {icon}
  </div>
  <h3 class={`text-xl font-bold mb-3 ${highlight ? 'text-white' : 'text-gray-900'}`}>
    {title}
  </h3>
  <p class={`text-sm leading-relaxed ${highlight ? 'text-blue-100' : 'text-gray-500'}`}>
    {description}
  </p>
  <div class={`mt-6 flex items-center gap-2 text-sm font-semibold ${highlight ? 'text-white' : 'text-blue-600'}`}>
    <span>Learn more</span>
    <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </div>
</div>
