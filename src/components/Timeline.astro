---
interface Milestone {
  year: number;
  title: string;
  description: string;
}

interface Props {
  milestones: Milestone[];
}

const { milestones } = Astro.props;
---

<section id="journey" class="py-24 bg-gray-50">
  <div class="max-w-4xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="text-sm font-bold text-blue-600 uppercase tracking-widest">Est. 2004</span>
      <h2 class="text-4xl font-black text-gray-900 mt-2 mb-4">Our 20-Year Journey</h2>
      <p class="text-gray-500 max-w-xl mx-auto">From a single office to 500+ corporate clients — here's how we grew.</p>
    </div>

    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-1/2 top-0 bottom-0 w-0.5 bg-gradient-to-b from-blue-600 via-indigo-400 to-transparent -translate-x-1/2 hidden md:block"></div>

      <div class="space-y-12">
        {milestones.map((milestone, i) => (
          <div class={`relative flex flex-col md:flex-row items-center gap-6 ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
            <!-- Content card -->
            <div class={`flex-1 ${i % 2 === 0 ? 'md:text-right' : 'md:text-left'}`}>
              <div class={`inline-block bg-white rounded-2xl p-6 shadow-md border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 max-w-sm ${i % 2 === 0 ? 'md:ml-auto' : ''}`}>
                <h3 class="text-lg font-bold text-gray-900 mb-2">{milestone.title}</h3>
                <p class="text-sm text-gray-500 leading-relaxed">{milestone.description}</p>
              </div>
            </div>

            <!-- Year badge (center) -->
            <div class="relative z-10 flex-shrink-0">
              <div class="w-16 h-16 rounded-full bg-gradient-to-br from-blue-600 to-indigo-700 flex items-center justify-center shadow-lg shadow-blue-500/30 ring-4 ring-white">
                <span class="text-xs font-black text-white text-center leading-tight">{milestone.year}</span>
              </div>
            </div>

            <!-- Spacer for alternating layout -->
            <div class="flex-1 hidden md:block"></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
