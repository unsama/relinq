---
import { getCollection, getEntry } from 'astro:content';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Timeline from '../components/Timeline.astro';
import '../styles/global.css';

// Load about content
const aboutEntry = await getEntry('about', 'about');
const { Content } = await aboutEntry.render();

// Load journey milestones sorted by year
const journeyEntries = await getCollection('journey');
const milestones = journeyEntries
  .sort((a, b) => a.data.year - b.data.year)
  .map(e => ({
    year: e.data.year,
    title: e.data.title,
    description: e.data.description,
  }));
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>About Us — Relinq</title>
    <meta name="description" content="22 years of IT solutions. Learn the story behind Relinq — how a single office grew into a 500+ client enterprise serving businesses nationwide." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
      body { font-family: 'Inter', sans-serif; }
      .prose-about h2 { font-size: 1.75rem; font-weight: 800; color: #111827; margin: 2rem 0 0.75rem; }
      .prose-about p { color: #6b7280; line-height: 1.8; margin-bottom: 1.25rem; }
      .prose-about strong { color: #1d4ed8; font-weight: 700; }
    </style>
  </head>
  <body class="bg-white text-gray-900 antialiased">
    <Header />

    <main>
      <!-- Hero -->
      <section class="relative pt-36 pb-20 bg-gradient-to-br from-slate-950 via-blue-950 to-indigo-950 overflow-hidden">
        <div class="absolute top-1/3 right-1/4 w-80 h-80 bg-blue-600/15 rounded-full blur-3xl"></div>
        <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
          <span class="text-sm font-bold text-blue-400 uppercase tracking-widest">Our Story</span>
          <h1 class="text-5xl md:text-6xl font-black text-white mt-3 mb-6 leading-tight">
            {aboutEntry.data.tagline}
          </h1>
          <p class="text-xl text-blue-100/70 max-w-xl mx-auto">
            {aboutEntry.data.mission}
          </p>
          <div class="flex items-center justify-center gap-6 mt-10 text-sm text-blue-300/60 font-semibold uppercase tracking-widest">
            <span>Est. {aboutEntry.data.founded}</span>
            <span>·</span>
            <span>R2 Certified</span>
            <span>·</span>
            <span>Dell · HP · Apple</span>
          </div>
        </div>
      </section>

      <!-- About Us Content -->
      <section class="py-24 bg-white">
        <div class="max-w-3xl mx-auto px-6">
          <!-- Quick trust badges -->
          <div class="flex flex-wrap gap-3 mb-12">
            {[
              { icon: '🏆', text: '22+ Years' },
              { icon: '♻️', text: 'R2 Certified' },
              { icon: '↩️', text: '3-Day Refund' },
              { icon: '🌐', text: 'Dell · HP · Apple' },
              { icon: '👥', text: '500+ Clients' },
            ].map(badge => (
              <span class="flex items-center gap-2 px-4 py-2 bg-blue-50 text-blue-700 rounded-full text-sm font-semibold border border-blue-100">
                <span>{badge.icon}</span>
                <span>{badge.text}</span>
              </span>
            ))}
          </div>

          <div class="prose-about">
            <Content />
          </div>

          <!-- CTA -->
          <div class="mt-12 p-8 rounded-3xl bg-gradient-to-br from-blue-600 to-indigo-700 text-white text-center shadow-xl shadow-blue-500/20">
            <h3 class="text-2xl font-black mb-3">Ready to work with us?</h3>
            <p class="text-blue-100 mb-6 text-sm">Join 500+ businesses that trust Relinq for their IT infrastructure.</p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a href="/#contact" class="px-7 py-3 rounded-xl bg-white text-blue-700 font-bold hover:bg-blue-50 transition-colors">
                Request a Quote →
              </a>
              <a href="/#contact" class="px-7 py-3 rounded-xl bg-white/15 font-bold hover:bg-white/25 transition-colors border border-white/20">
                Book an Audit
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- 20-Year Timeline -->
      <Timeline milestones={milestones} />
    </main>

    <Footer />
  </body>
</html>
