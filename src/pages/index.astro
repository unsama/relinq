---
import { getCollection } from 'astro:content';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { AnimatedSection, AnimatedItem } from '../components/AnimatedSection';
import '../styles/global.css';

const services = [
  {
    icon: '🖥️',
    title: 'Wholesale IT Hardware',
    description: 'Globally sourced Dell, HP, Apple & more — enterprise-grade hardware at competitive bulk prices for businesses of every scale.',
    badge: 'Most Popular',
    highlight: false,
  },
  {
    icon: '🔧',
    title: 'Corporate AMC Solutions',
    description: 'Annual Maintenance Contracts with guaranteed SLAs, on-site response, and dedicated account managers who actually answer the phone.',
    badge: 'Enterprise',
    highlight: true,
  },
  {
    icon: '♻️',
    title: 'R2-Certified Refurbishing',
    description: 'Environmentally compliant, performance-tested refurbished devices. Every unit data-wiped, tested, and certified before delivery.',
    badge: 'R2 Certified',
    highlight: false,
  },
];

const stats = [
  { value: '22+', label: 'Years in Business' },
  { value: '500+', label: 'Corporate Clients' },
  { value: '10K+', label: 'Devices Refurbished' },
];

const whyUs = [
  {
    icon: '🏆',
    title: '22 Years of Trust',
    description: 'Founded in 2004, we have been a reliable partner for over two decades of business technology.',
  },
  {
    icon: '↩️',
    title: '3-Day Refund Policy',
    description: 'No-hassle returns on all hardware. We stand behind every product we deliver.',
  },
  {
    icon: '🌐',
    title: 'Global Brand Partnerships',
    description: 'Authorized reseller for Dell, HP, and Apple — wholesale sourced, locally supported.',
  },
  {
    icon: '♻️',
    title: 'R2 Certified',
    description: 'Environmentally responsible and data-secure. The highest standard in IT asset disposition.',
  },
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Relinq — Reliable Tech for Growth</title>
    <meta name="description" content="22 years of trusted IT solutions. Wholesale hardware, AMC contracts, and R2-certified refurbishing for businesses that demand reliability." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
      body { font-family: 'Inter', sans-serif; }
    </style>
  </head>
  <body class="bg-white text-gray-900 antialiased">
    <Header />

    <main>
      <!-- ═══════════════════════════════════════
           HERO
      ═══════════════════════════════════════ -->
      <section class="relative min-h-screen flex items-center overflow-hidden bg-gradient-to-br from-slate-950 via-blue-950 to-indigo-950">
        <!-- Animated gradient orbs -->
        <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-blue-600/20 rounded-full blur-3xl animate-pulse"></div>
        <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-indigo-600/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-blue-500/5 rounded-full blur-3xl"></div>

        <div class="relative max-w-7xl mx-auto px-6 pt-32 pb-20 text-center">
          <!-- Badge -->
          <div class="inline-flex items-center gap-2 bg-blue-500/10 border border-blue-500/30 rounded-full px-5 py-2 text-blue-300 text-sm font-semibold mb-8 backdrop-blur-sm">
            <span class="w-2 h-2 rounded-full bg-blue-400 animate-pulse"></span>
            R2 Certified · 22 Years in Business · 500+ Clients
          </div>

          <!-- Headline -->
          <h1 class="text-6xl md:text-7xl lg:text-8xl font-black text-white mb-6 leading-none tracking-tight">
            Reliable Tech<br />
            <span class="bg-gradient-to-r from-blue-400 to-indigo-400 bg-clip-text text-transparent">
              for Growth.
            </span>
          </h1>

          <!-- Sub-headline -->
          <p class="text-xl md:text-2xl text-blue-100/70 max-w-2xl mx-auto mb-12 leading-relaxed font-medium">
            22 years of trusted IT solutions — wholesale hardware, corporate maintenance contracts, and R2-certified refurbishing for businesses that mean business.
          </p>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="#contact"
              class="w-full sm:w-auto px-8 py-4 rounded-2xl bg-gradient-to-r from-blue-500 to-indigo-600 text-white font-bold text-lg shadow-2xl shadow-blue-500/40 hover:shadow-blue-500/60 hover:-translate-y-1 transition-all duration-300"
            >
              Request Wholesale Quote →
            </a>
            <a
              href="#contact"
              class="w-full sm:w-auto px-8 py-4 rounded-2xl bg-white/10 border border-white/20 text-white font-bold text-lg hover:bg-white/20 hover:-translate-y-1 transition-all duration-300 backdrop-blur-sm"
            >
              Book Maintenance Audit
            </a>
          </div>

          <!-- Social proof brands -->
          <div class="mt-16 flex flex-col items-center gap-4">
            <p class="text-blue-300/60 text-sm font-semibold uppercase tracking-widest">Authorized Reseller</p>
            <div class="flex items-center gap-8 text-white/40 text-sm font-black uppercase tracking-wider">
              <span>Dell</span>
              <span class="w-1 h-1 rounded-full bg-white/20"></span>
              <span>HP</span>
              <span class="w-1 h-1 rounded-full bg-white/20"></span>
              <span>Apple</span>
              <span class="w-1 h-1 rounded-full bg-white/20"></span>
              <span>Lenovo</span>
            </div>
          </div>
        </div>

        <!-- Scroll indicator -->
        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-blue-400/60">
          <span class="text-xs font-medium uppercase tracking-widest">Scroll</span>
          <div class="w-px h-8 bg-gradient-to-b from-blue-400/60 to-transparent"></div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════
           SERVICES
      ═══════════════════════════════════════ -->
      <section id="services" class="py-28 bg-gray-50">
        <div class="max-w-7xl mx-auto px-6">
          <div class="text-center mb-16">
            <span class="text-sm font-bold text-blue-600 uppercase tracking-widest">Core Services</span>
            <h2 class="text-4xl md:text-5xl font-black text-gray-900 mt-2 mb-4">What We Do Best</h2>
            <p class="text-lg text-gray-500 max-w-xl mx-auto">Enterprise-grade IT solutions built on two decades of hands-on expertise.</p>
          </div>

          <AnimatedSection className="grid grid-cols-1 md:grid-cols-3 gap-8" client:visible>
            {services.map((service) => (
              <AnimatedItem>
                <ServiceCard
                  icon={service.icon}
                  title={service.title}
                  description={service.description}
                  badge={service.badge}
                  highlight={service.highlight}
                />
              </AnimatedItem>
            ))}
          </AnimatedSection>
        </div>
      </section>

      <!-- ═══════════════════════════════════════
           WHY US
      ═══════════════════════════════════════ -->
      <section id="why-us" class="py-28 bg-white">
        <div class="max-w-7xl mx-auto px-6">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <!-- Left: text -->
            <div>
              <span class="text-sm font-bold text-blue-600 uppercase tracking-widest">Why Relinq</span>
              <h2 class="text-4xl md:text-5xl font-black text-gray-900 mt-2 mb-6 leading-tight">
                Built on Trust.<br />Backed by Results.
              </h2>
              <p class="text-lg text-gray-500 mb-10 leading-relaxed">
                We're not just another hardware vendor. We're your long-term technology partner — with the credentials, policies, and partnerships to prove it.
              </p>
              <div class="flex flex-col gap-6">
                {whyUs.map((item) => (
                  <div class="flex items-start gap-5">
                    <div class="w-12 h-12 rounded-2xl bg-blue-50 flex items-center justify-center flex-shrink-0 text-2xl">
                      {item.icon}
                    </div>
                    <div>
                      <h3 class="font-bold text-gray-900 mb-1">{item.title}</h3>
                      <p class="text-sm text-gray-500 leading-relaxed">{item.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Right: decorative card -->
            <div class="relative">
              <div class="rounded-3xl bg-gradient-to-br from-blue-600 to-indigo-700 p-10 text-white shadow-2xl shadow-blue-500/30">
                <div class="text-6xl mb-6">🛡️</div>
                <h3 class="text-3xl font-black mb-4">Our Guarantee</h3>
                <ul class="space-y-4">
                  <li class="flex items-center gap-3 text-blue-100">
                    <span class="text-green-400 font-bold text-lg">✓</span>
                    <span>3-day no-hassle refund on all hardware</span>
                  </li>
                  <li class="flex items-center gap-3 text-blue-100">
                    <span class="text-green-400 font-bold text-lg">✓</span>
                    <span>R2-certified data wiping on all refurbished devices</span>
                  </li>
                  <li class="flex items-center gap-3 text-blue-100">
                    <span class="text-green-400 font-bold text-lg">✓</span>
                    <span>Dedicated account manager for every corporate client</span>
                  </li>
                  <li class="flex items-center gap-3 text-blue-100">
                    <span class="text-green-400 font-bold text-lg">✓</span>
                    <span>SLA-backed response times on all AMC contracts</span>
                  </li>
                </ul>
                <div class="mt-8 pt-6 border-t border-white/20 flex items-center gap-4">
                  <div class="text-center">
                    <div class="text-3xl font-black">22+</div>
                    <div class="text-xs text-blue-200">Years</div>
                  </div>
                  <div class="w-px h-10 bg-white/20"></div>
                  <div class="text-center">
                    <div class="text-3xl font-black">500+</div>
                    <div class="text-xs text-blue-200">Clients</div>
                  </div>
                  <div class="w-px h-10 bg-white/20"></div>
                  <div class="text-center">
                    <div class="text-3xl font-black">10K+</div>
                    <div class="text-xs text-blue-200">Devices</div>
                  </div>
                </div>
              </div>
              <!-- Decorative backdrop -->
              <div class="absolute -z-10 -bottom-4 -right-4 w-full h-full rounded-3xl bg-indigo-100"></div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════
           STATS ROW
      ═══════════════════════════════════════ -->
      <section class="bg-gradient-to-r from-blue-600 to-indigo-700 py-20">
        <div class="max-w-7xl mx-auto px-6">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-10 text-center text-white">
            {stats.map(stat => (
              <div>
                <div class="text-6xl font-black mb-2">{stat.value}</div>
                <div class="text-blue-200 font-semibold text-lg">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════
           CTA BANNER
      ═══════════════════════════════════════ -->
      <section id="contact" class="py-28 bg-gray-950">
        <div class="max-w-4xl mx-auto px-6 text-center">
          <span class="text-sm font-bold text-blue-400 uppercase tracking-widest">Get Started</span>
          <h2 class="text-4xl md:text-5xl font-black text-white mt-3 mb-6 leading-tight">
            Ready to Upgrade<br />Your IT Infrastructure?
          </h2>
          <p class="text-lg text-gray-400 mb-12 max-w-2xl mx-auto">
            Whether you need 5 laptops or 500, an AMC for your entire fleet, or certified refurbished hardware — Relinq delivers. Let's talk.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href="mailto:quotes@relinq.com"
              class="px-10 py-4 rounded-2xl bg-gradient-to-r from-blue-500 to-indigo-600 text-white font-bold text-lg shadow-2xl shadow-blue-500/30 hover:shadow-blue-500/50 hover:-translate-y-1 transition-all duration-300"
            >
              📦 Request Wholesale Quote
            </a>
            <a
              href="mailto:audit@relinq.com"
              class="px-10 py-4 rounded-2xl bg-white/10 border border-white/20 text-white font-bold text-lg hover:bg-white/15 hover:-translate-y-1 transition-all duration-300 backdrop-blur-sm"
            >
              🔍 Book Maintenance Audit
            </a>
          </div>
          <p class="mt-8 text-gray-600 text-sm">3-Day Refund Guarantee &nbsp;·&nbsp; R2 Certified &nbsp;·&nbsp; Est. 2004</p>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
