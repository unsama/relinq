---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TrustRibbon from '../components/TrustRibbon.astro';
import ProductCard from '../components/ProductCard.astro';
import { BrandCarousel } from '../components/BrandCarousel';
import '../styles/global.css';

const featuredProducts = [
  {
    title: 'Dell Latitude 7420 | Core i7 11th Gen',
    brand: 'Dell',
    specs: ['Intel Core i7-1185G7', '16GB RAM', '512GB NVMe SSD', '14" FHD Display'],
    imageUrl: 'https://upload.wikimedia.org/wikipedia/commons/e/e8/Dell_Latitude_7400.png',
    stockStatus: 'In Stock (Bulk)'
  },
  {
    title: 'HP EliteDesk 800 G6 SFF',
    brand: 'HP',
    specs: ['Intel Core i5 10th Gen', '16GB DDR4', '256GB SSD', 'Win 10 Pro'],
    imageUrl: 'https://upload.wikimedia.org/wikipedia/commons/e/eb/HP_EliteDesk.png',
    stockStatus: 'Available'
  },
  {
    title: 'Lenovo ThinkPad T14 Gen 2',
    brand: 'Lenovo',
    specs: ['Intel Core i5 11th Gen', '16GB RAM', '512GB SSD', '14" IPS'],
    imageUrl: 'https://upload.wikimedia.org/wikipedia/commons/a/ae/ThinkPad_T490.png',
    stockStatus: 'Limited Stock'
  },
  {
    title: 'Dell UltraSharp 24" U2422H',
    brand: 'Dell',
    specs: ['24" IPS Panel', '1080p Resolution', 'USB-C Hub', 'Ergonomic Stand'],
    imageUrl: 'https://upload.wikimedia.org/wikipedia/commons/a/ad/Dell_Ultrasharp.png',
    stockStatus: 'In Stock (Bulk)'
  }
];

---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Relinq Solutions - Premium Imported IT Hardware</title>
    <meta name="description" content="Empowering Pakistan's Businesses with Smarter Tech. Premium Imported & R2 Refurbished IT Solutions based in Karachi." />
  </head>
  <body class="bg-[#F8FAFC] text-[#0F172A] antialiased pt-[72px]">
    <Header />

    <main>
      <!-- Hero Section -->
      <section class="relative bg-white border-b border-gray-100 py-16 md:py-24 overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-blue-50/50 via-white to-white -z-10"></div>
        <div class="max-w-7xl mx-auto px-4 md:px-6">
          <div class="flex flex-col md:flex-row items-center gap-12">
            <div class="flex-1 text-center md:text-left">
              <span class="inline-block py-1 px-3 rounded-full bg-blue-50 border border-blue-100 text-blue-800 text-xs font-bold tracking-widest uppercase mb-6">
                Premium B2B Wholesale
              </span>
              <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-[#1E3A8A] leading-tight mb-6">
                Empowering Pakistan’s Businesses with <span class="text-[#22C55E]">Smarter Tech.</span>
              </h1>
              <p class="text-lg text-slate-600 mb-8 max-w-2xl mx-auto md:mx-0 font-medium leading-relaxed">
                Premium Imported & R2 Refurbished IT Solutions. Scale your enterprise infrastructure with reliable hardware backed by quality assurance and nationwide support.
              </p>
              <div class="flex flex-col sm:flex-row items-center gap-4 justify-center md:justify-start">
                <a href="#featured" class="px-8 py-3.5 bg-[#22C55E] hover:bg-[#16A34A] text-white rounded-md font-bold shadow-lg transition-transform hover:-translate-y-0.5 whitespace-nowrap">
                  View Bulk Inventory
                </a>
                <a href="https://wa.me/923000000000?text=I'd%20like%20your%20bulk%20inventory%20list" class="px-8 py-3.5 bg-white border-2 border-slate-200 text-slate-700 hover:border-slate-300 hover:bg-slate-50 rounded-md font-bold transition-all whitespace-nowrap flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                  Download Excel Price List
                </a>
              </div>
            </div>
            <div class="flex-1 relative w-full max-w-lg mx-auto">
              <div class="aspect-[4/3] bg-slate-100 rounded-2xl overflow-hidden shadow-2xl border border-white/50 relative">
                <!-- Placeholder for Hero Image -->
                <div class="absolute inset-0 bg-gradient-to-br from-blue-900 to-[#1E3A8A] flex items-center justify-center text-white/50 animate-pulse">
                  <span class="font-bold tracking-widest uppercase">Premium Laptops Image</span>
                </div>
              </div>
              <div class="absolute -bottom-6 -left-6 bg-white p-4 rounded-xl shadow-xl flex items-center gap-4 border border-slate-100">
                <div class="w-12 h-12 bg-green-100 text-green-600 rounded-full flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </div>
                <div>
                  <div class="text-xs text-slate-500 font-bold uppercase">Quality Checked</div>
                  <div class="font-bold text-slate-900">100% Tested</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Trust Ribbon -->
      <TrustRibbon />

      <!-- Featured Categories -->
      <section id="featured" class="py-20 bg-[#F8FAFC]">
        <div class="max-w-7xl mx-auto px-4 md:px-6">
          <div class="flex items-end justify-between mb-10">
            <div>
              <span class="text-sm font-bold text-[#22C55E] uppercase tracking-widest block mb-2">Inventory Spotlight</span>
              <h2 class="text-3xl font-black text-[#1E3A8A]">Featured Wholesale Deals</h2>
            </div>
            <a href="/products" class="hidden sm:inline-flex items-center gap-2 text-sm font-bold text-[#1E3A8A] hover:text-[#1E3A8A]/80 transition-colors">
              View All Stock
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {featuredProducts.map(product => (
              <ProductCard {...product} />
            ))}
          </div>
          
          <div class="mt-10 text-center sm:hidden">
            <a href="/products" class="inline-flex items-center gap-2 text-sm font-bold px-6 py-3 bg-white border border-slate-200 shadow-sm rounded-md text-[#1E3A8A] hover:bg-slate-50">
              View All Stock
            </a>
          </div>
        </div>
      </section>

      <!-- About Us -->
      <section class="py-24 bg-white border-y border-gray-100">
        <div class="max-w-7xl mx-auto px-4 md:px-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
            <div class="order-2 md:order-1 relative">
              <div class="aspect-square bg-slate-100 rounded-3xl overflow-hidden shadow-lg border border-slate-200 flex items-center justify-center">
                 <div class="text-slate-400 font-bold uppercase tracking-widest">Office / Warehouse Image</div>
              </div>
              <div class="absolute -top-8 -right-8 w-48 h-48 bg-blue-50 rounded-full -z-10"></div>
              <div class="absolute -bottom-8 -left-8 w-32 h-32 bg-green-50 rounded-full -z-10"></div>
            </div>
            
            <div class="order-1 md:order-2">
              <span class="text-sm font-bold text-[#22C55E] uppercase tracking-widest block mb-2">Corporate Profile</span>
              <h2 class="text-3xl font-black text-[#1E3A8A] mb-6">Your Partner in High-Performance IT since 2024</h2>
              
              <div class="space-y-4 text-slate-600 font-medium leading-relaxed mb-8">
                <p>
                  At Relinq Solutions Pvt. Ltd., we understand that enterprise technology needs to be both reliable and cost-effective. Based in the heart of Saddar, Karachi, we bypass the standard used market to bring you premium R2 Certified refurbished hardware.
                </p>
                <p>
                  Over the past year, we have established ourselves as the preferred IT hardware partner for businesses, call centers, and logistics hubs across Pakistan.
                </p>
              </div>

              <div class="grid grid-cols-2 gap-6 mb-8 pt-6 border-t border-slate-100">
                <div>
                  <div class="text-3xl font-black text-[#1E3A8A] mb-1">100%</div>
                  <div class="text-sm font-bold text-slate-500">Tested Quality</div>
                </div>
                <div>
                  <div class="text-3xl font-black text-[#1E3A8A] mb-1">B2B</div>
                  <div class="text-sm font-bold text-slate-500">Bulk Distribution</div>
                </div>
              </div>

              <a href="https://wa.me/923000000000" class="inline-flex items-center gap-2 px-6 py-3 bg-[#1E3A8A] text-white rounded-md font-bold hover:bg-[#1E3A8A]/90 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                Contact Saddar Office
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- Brand Showcase -->
      <section id="brands">
        <BrandCarousel client:visible />
      </section>

    </main>

    <Footer />
  </body>
</html>
